@startuml
skinparam classAttributeIconSize 0
left to right direction

title Sistema de Gerenciamento de Museus e Galerias de Arte

' =========================
' CLASSES
' =========================

class Usuario {
    - id: int
    - dataNascimento: Date
    - nome: String
    - telefone: String
    - email: String
    - cpf: String
    - login: String
    - senha: String
    + cadastrarUsuario()
    + atualizarUsuario()
    + excluirUsuario()
}

class Funcionario {
    - cargo: String
    - salario: double
    - dataAdmissao: Date
    + gerenciarExposicao()
    + cadastrarObra()
    + gerarRelatorio()
}

class Visitante {
    - dataCadastro: Date
    + comprarIngresso()
    + realizarReserva()
}

class Artista {
    - nacionalidade: String
    - estiloArtistico: String
    + cadastrarArtista()
    + atualizarPortfolio()
}

class Galeria {
    - id: int
    - nome: String
    - descricao: String
    - endereco: String
    + abrirGaleria()
    + fecharGaleria()
}

class Exposicao {
    - id: int
    - titulo: String
    - descricao: String
    - dataInicio: Date
    - dataFim: Date
    - status: String
    + iniciarExposicao()
    + encerrarExposicao()
}

class ObraArte {
    - id: int
    - titulo: String
    - tecnica: String
    - anoCriacao: int
    - valorEstimado: double
    + restaurar()
    + calcularValor()
}

class CategoriaObra {
    - id: int
    - nome: String
    - descricao: String
    + cadastrarCategoria()
}

class CertificadoAutenticidade {
    - codigo: String
    - dataEmissao: Date
    - orgaoResponsavel: String
    + validarCertificado()
}

class Restauracao {
    - id: int
    - dataInicio: Date
    - dataFim: Date
    - descricao: String
    - custo: double
    + iniciarRestauracao()
    + finalizarRestauracao()
}

class Ingresso {
    - id: int
    - tipo: String
    - valor: double
    - dataCompra: Date
    - status: String
    + gerarIngresso()
}

class Reserva {
    - id: int
    - dataReserva: Date
    - quantidadePessoas: int
    - status: String
    + confirmarReserva()
    + cancelarReserva()
}

class Pagamento {
    - id: int
    - valor: double
    - dataPagamento: Date
    - metodo: String
    - status: String
    + realizarPagamento()
    + estornarPagamento()
}

class Avaliacao {
    - id: int
    - nota: int
    - comentario: String
    - dataAvaliacao: Date
    + avaliarExposicao()
}

' =========================
' CLASSES ASSOCIATIVAS
' =========================

class ExposicaoObra {
    - dataEntrada: Date
    - posicaoSala: String
    - iluminaçãoEspecial: String
    - StatusConservação: String
    - EstiloObra: String

}

class ArtistaObra {
    - funcao: String
    - dataParticipacao: Date
}

' =========================
' HERANÇA
' =========================

Usuario <|-- Funcionario
Usuario <|-- Visitante
Usuario <|-- Artista

' =========================
' RELACIONAMENTOS PRINCIPAIS
' =========================

Galeria "1" -- "*" Exposicao : possui

CategoriaObra "1" -- "*" ObraArte : classifica

Funcionario "*" -- "1" Galeria : trabalha em

Visitante "1" -- "*" Ingresso : compra
Visitante "1" -- "*" Reserva : realiza
Visitante "1" -- "*" Avaliacao : faz

Ingresso "*" -- "1" Exposicao : acesso para
Reserva "*" -- "1" Exposicao : reserva para

Ingresso "1" -- "1" Pagamento : pagamento
Reserva "1" -- "1" Pagamento : pagamento

ObraArte "1" -- "*" Restauracao : passa por
Funcionario "1" -- "*" Restauracao : realiza

Restauracao "1" -- "1" Pagamento : gera

ObraArte "1" -- "1" CertificadoAutenticidade : possui

Exposicao "1" -- "*" Avaliacao : recebe

' =========================
' MANY TO MANY
' =========================

Exposicao "1" -- "*" ExposicaoObra
ObraArte "1" -- "*" ExposicaoObra

Artista "1" -- "*" ArtistaObra
ObraArte "1" -- "*" ArtistaObra

' =========================
' ORGANIZAÇÃO VISUAL
' =========================

Galeria -[hidden]- CategoriaObra
Exposicao -[hidden]- ObraArte
Ingresso -[hidden]- Reserva
Pagamento -[hidden]- Restauracao
@enduml